# --- Secrets (belt-and-suspenders; sub-dir .gitignores also cover these) ---
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.python-version
.venv/
venv/
env/

# --- Test / coverage ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# --- Node / frontend ---
node_modules/
**/node_modules/
.npm/
.pnpm-store/
*.tsbuildinfo
**/dist/
**/dist-ssr/
*.local

# --- Editor / OS ---
.idea/
.vscode/*
!.vscode/extensions.json
.DS_Store
Thumbs.db
*.swp
*.suo
*.ntvs*
*.njsproj
*.sln

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Local data ---
*.sqlite
*.sqlite-journal
*.db
data/

# --- Build artifacts ---
*.zip

# --- Submission bundle: keep docs + JSON, ignore the (potentially large) recording ---
submission/screen-recording.*
submission/*.mp4
submission/*.mov
submission/*.webm
submission/*.mkv
