# ---------------------------------------------------------------------------
# AI Triage Pipeline — environment template
# Copy to .env (gitignored) and fill in real values.
# ---------------------------------------------------------------------------

# Runtime
ENV=dev
LOG_LEVEL=INFO
LOG_FORMAT=console            # console | json

# API
API_HOST=0.0.0.0
API_PORT=8000
INTERNAL_API_KEYS=             # comma-separated list; empty = no auth (dev only)

# Database
DATABASE_URL=postgresql+asyncpg://app:app@postgres:5432/app
DB_ECHO=false

# Redis / queue
REDIS_URL=redis://redis:6379/0

# LLM provider keys (at least one required to actually run the pipeline)
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434

# LLM model identifiers — fallback chain in order
LLM_PRIMARY_MODEL=groq/llama-3.3-70b-versatile
LLM_FALLBACK_MODELS=gemini/gemini-2.0-flash,openai/gpt-4o-mini,ollama/llama3.1
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=30

# Escalation thresholds (Step 6 rules)
ESCALATION_CONFIDENCE_THRESHOLD=0.70
ESCALATION_BILLING_THRESHOLD_USD=500
ESCALATION_KEYWORDS=outage,down for all users,production down,data loss,security breach

# Worker
WORKER_MAX_JOBS=20
WORKER_JOB_TIMEOUT=300
WORKER_MAX_TRIES=5

# Observability (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
