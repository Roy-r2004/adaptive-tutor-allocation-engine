# Root-level Docker Compose env. ONLY needed if the standard ports collide
# with something else running on your host. Reviewers on a clean machine can
# delete or ignore this file.
#
# Example: if you already have Postgres and Redis running locally:
#   POSTGRES_PORT=5434
#   REDIS_PORT=6380
#   API_PORT=8001
#   FRONTEND_PORT=5173
#
# The root docker-compose.yml interpolates these against defaults.

POSTGRES_PORT=5432
REDIS_PORT=6379
API_PORT=8000
FRONTEND_PORT=5173
