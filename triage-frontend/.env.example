# Base URL of the running triage backend.
# In dev: http://localhost:8000 (default)
# In Docker compose: http://app:8000 (uses service name)
VITE_API_BASE_URL=http://localhost:8000

# Optional. Only set if backend's INTERNAL_API_KEYS is populated.
# Leave empty for dev (matches the backend's empty-keys = open mode).
VITE_API_KEY=

# One of: dev | staging | prod — used purely for the footer indicator.
VITE_ENV=dev
